// Minimal schema for Zyra - just enough to get running
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id          String    @id @default(cuid())
  email       String    @unique
  name        String?
  password    String
  role        String    @default("VIEWER")
  isVerified  Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  sessions    Session[]
  apiKeys     ApiKey[]
  passwordResets PasswordReset[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ApiKey {
  id          String   @id @default(cuid())
  userId      String
  name        String
  key         String   @unique
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PasswordReset {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Organization {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  plan        String   @default("FREE")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users       OrganizationUser[]
  assets      Asset[]
  scans       Scan[]
  incidents   Incident[]
  activities  Activity[]
  webhooks    Webhook[]
  jobs        Job[]
}

model OrganizationUser {
  id             String       @id @default(cuid())
  userId         String
  orgId          String
  role           String       @default("VIEWER")
  createdAt      DateTime     @default(now())

  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([userId, orgId])
}

model Asset {
  id        String   @id @default(cuid())
  name      String
  type      String
  url       String?
  orgId     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  scans     Scan[]
}

model Scan {
  id          String   @id @default(cuid())
  type        String
  status      String   @default("PENDING")
  targetUrl   String?
  score       Int?
  riskLevel   String?
  summary     String?
  orgId       String
  assetId     String?
  createdAt   DateTime @default(now())
  startedAt   DateTime?
  completedAt DateTime?
  updatedAt   DateTime @updatedAt

  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  asset       Asset?       @relation(fields: [assetId], references: [id], onDelete: SetNull)
}

model Incident {
  id          String   @id @default(cuid())
  title       String
  severity    String
  status      String   @default("OPEN")
  description String?
  orgId       String
  assignedTo  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
}

model Activity {
  id          String   @id @default(cuid())
  action      String
  entityType  String
  entityId    String?
  description String?
  orgId       String
  userId      String
  createdAt   DateTime @default(now())

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
}

model Webhook {
  id          String   @id @default(cuid())
  name        String
  url         String
  events      String
  secret      String?
  active      Boolean  @default(true)
  orgId       String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
}

model Job {
  id          String   @id @default(cuid())
  type        String
  status      String   @default("PENDING")
  payload     String
  result      String?
  scheduledAt DateTime @default(now())
  startedAt   DateTime?
  completedAt DateTime?
  orgId       String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
}