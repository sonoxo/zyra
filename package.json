{
  "name": "zyra-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:web\" \"npm run dev:api\"",
    "dev:web": "npm run dev --workspace=apps/web",
    "dev:api": "npm run dev --workspace=apps/api",
    "build": "npm run build --workspaces",
    "build:web": "npm run build --workspace=apps/web",
    "build:api": "npm run build --workspace=apps/api",
    "start": "concurrently \"npm run start:web\" \"npm run start:api\"",
    "start:web": "npm run start --workspace=apps/web",
    "start:api": "npm run start --workspace=apps/api",
    "lint": "npm run lint --workspace=apps/web",
    "test": "npx tsx packages/agents/src/index.test.ts && npx tsx packages/config/src/index.test.ts && npx tsx packages/types/src/index.test.ts",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev"
  },
  "devDependencies": {
    "@types/ws": "^8.18.1",
    "@vitest/ui": "^2.0.0",
    "concurrently": "^8.2.2",
    "typescript": "^5.3.3",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@prisma/client": "^5.15.0",
    "@sentry/node": "^10.47.0",
    "prisma": "5.15.0",
    "zod": "^4.3.6"
  }
}
