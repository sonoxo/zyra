# ── Required ──────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/zyra
JWT_SECRET=your-jwt-secret-here

# ── URLs ─────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5000
BACKEND_URL=http://localhost:5000

# ── Stripe (test mode) — https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_...
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ── Email (Resend) — https://resend.com/api-keys
RESEND_API_KEY=re_...
EMAIL_FROM=Zyra <noreply@zyra.host>

# ── AI Vision (Hugging Face) — https://huggingface.co/settings/tokens
HF_TOKEN=hf_...

# ── Admin Bootstrap ──────────────────────────────────────────
BOOTSTRAP_SECRET=your-bootstrap-secret-here

# ── Optional / Observability ─────────────────────────────────
# SENTRY_DSN=https://...@sentry.io/...
# NODE_ENV=production
