{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "allowJs": true,
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "strictBindCallApply": true,
    "strictPropertyInitialization": true,
    "noImplicitThis": true,
    "alwaysStrict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "paths": {
      "@zyra/config": ["./packages/config/src"],
      "@zyra/types": ["./packages/types/src"],
      "@zyra/agents": ["./packages/agents/src"],
      "@zyra/monitoring": ["./packages/monitoring/src"]
    },
    "plugins": [{ "name": "next" }]
  },
  "include": ["next.config.mjs", "**/*.ts", "**/*.tsx"],
  "exclude": ["node_modules", "apps/*/node_modules", "packages/*/node_modules"]
}
