{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "allowJs": true,
    "strict": false,
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "paths": {
      "@zyra/config": ["./packages/config/src"],
      "@zyra/types": ["./packages/types/src"],
      "@zyra/agents": ["./packages/agents/src"]
    },
    "plugins": [{ "name": "next" }]
  },
  "include": ["next.config.mjs", "**/*.ts", "**/*.tsx"],
  "exclude": ["node_modules", "apps/*/node_modules", "packages/*/node_modules"]
}
